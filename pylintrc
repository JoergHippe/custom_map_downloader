[MASTER]
persistent = yes

[MESSAGES CONTROL]
disable =
    C0103,
    R0903

[REPORTS]
reports = no
score = no

[FORMAT]
max-line-length = 100
ignore-long-lines = ^\s*(# )?<?https?://\S+>?$

[TYPECHECK]
ignore-mixin-members = yes
generated-members =
    REQUEST,
    acl_users,
    aq_parent

[DESIGN]
max-args = 8
max-locals = 20
max-returns = 8
max-branches = 15
max-statements = 60
max-attributes = 10

[EXCEPTIONS]
overgeneral-exceptions = Exception
